# Dependencies
/vendor/

# Symfony runtime/cache artifacts
/var/
!/var/.gitignore

# Local environment overrides
/.env.local
/.env.local.php
/.env.*.local

# PHPUnit cache
/.phpunit.result.cache

# Local JWT keypair
/config/jwt/*.pem

# User uploads (keep directory placeholders only)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/posts/
/public/uploads/posts/*
!/public/uploads/posts/.gitkeep

