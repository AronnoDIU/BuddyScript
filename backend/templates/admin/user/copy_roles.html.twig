{% extends '@SonataAdmin/standard_layout.html.twig' %}

{% block sonata_admin_content %}
<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <form action="{{ path('admin_core_user_copy_roles') }}" method="post">
        <div class="form-group row">
            <label for="inputEmail3" class="col-sm-2 col-form-label">From User</label>
            <div class="col-sm-10">
                <select class="form-control" id="from_user" name="from_user" required>
                    <option value="" selected>Please choose an option</option>
                    {% for user in users %}
                        <option value="{{ user.id }}">{{ user.id ~ '-' ~ user.username }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="form-group row">
            <label for="inputPassword3" class="col-sm-2 col-form-label">To User</label>
            <div class="col-sm-10">
                <select class="form-control" id="to_user" name="to_user" required>
                    <option value="" selected>Please choose an option</option>
                    {% for user in users %}
                        <option value="{{ user.id }}">{{ user.id ~ '-' ~ user.username }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-sm-6">
                <a href="{{ path('admin_core_user_list') }}" class="btn btn-primary">Back To User List</a>
            </div>
            <div class="col-sm-6 text-right">
                <button type="submit" class="btn btn-primary">Submit</button>
            </div>
        </div>
    </form>
</div>
{% endblock %}
