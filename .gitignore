#############################
# Global OS / Editor
#############################
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*.tmp

.idea/
.vscode/
*.iml

#############################
# Logs / temp / process files
#############################
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.web-server-pid

#############################
# Environment / secrets
#############################
.env
.env.local
.env.*.local
!.env.example

#############################
# Legacy import artifacts
#############################
__MACOSX/

#############################
# Node / frontend tool output (monorepo-wide)
#############################
node_modules/
dist/
build/
coverage/
.eslintcache
.vite/

#############################
# Symfony backend (backend/)
#############################
backend/vendor/
backend/var/
!backend/var/.gitignore
backend/.phpunit.result.cache
backend/.env.local.php

# Never commit runtime uploads.
backend/public/uploads/*
!backend/public/uploads/.gitkeep
!backend/public/uploads/posts/
backend/public/uploads/posts/*
!backend/public/uploads/posts/.gitkeep

# Never commit local JWT keypair material.
backend/config/jwt/*.pem

#############################
# Frontend package output (frontend/)
#############################
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.eslintcache
frontend/.vite/
